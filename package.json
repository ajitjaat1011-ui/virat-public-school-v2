{
  "name": "virat-public-school",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev --d1=vps-database --compatibility-date=2025-05-01 --port 8788",
    "deploy": "wrangler pages deploy ./public",
    "db:init:local": "wrangler d1 execute vps-database --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute vps-database --remote --file=./schema.sql",
    "db:seed:local": "wrangler d1 execute vps-database --local --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute vps-database --remote --file=./seed.sql"
  },
  "devDependencies": {
    "wrangler": "^4.86.0"
  }
}
